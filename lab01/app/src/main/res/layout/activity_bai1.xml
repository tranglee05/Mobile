<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="horizontal"
    android:weightSum="5"
    tools:context=".Bai1Activity">
    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="match_parent"
        android:layout_weight="1"
        android:background="#FBD353">

        <TextView
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:text="Android"
            android:textAlignment="center"
            android:textColor="#C72A2A"
            android:textSize="25sp" />
    </LinearLayout>

    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="match_parent"
        android:layout_weight="1"
        android:background="#CDFB98">

        <TextView
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:text="PHP"
            android:textAlignment="center"
            android:textColor="#1D1C1C"
            android:textSize="30sp" />
    </LinearLayout>

    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="match_parent"
        android:layout_weight="1"
        android:background="#59E702">

        <TextView
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:text="JAVA"
            android:textAlignment="center"
            android:textColor="#52085F"
            android:textSize="30sp" />
    </LinearLayout>

    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="match_parent"
        android:layout_weight="1"
        android:background="#9C27B0">

        <TextView
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:text="NodeJS"
            android:textAlignment="center"
            android:textColor="#0C3556"
            android:textSize="30sp" />
    </LinearLayout>

    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="match_parent"
        android:layout_weight="1"
        android:background="#FF9800">

        <TextView
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:text="JAVAScript"
            android:textAlignment="center"
            android:textColor="#064E47"
            android:textSize="30sp" />
    </LinearLayout>
</LinearLayout>